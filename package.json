{
  "name": "@kevinmichaelchen/distilled",
  "version": "0.2.0",
  "description": "Protocol-based Effect runtime and generators for Distilled SDKs",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinmichaelchen/distilled.git"
  },
  "files": ["lib", "src", "scripts"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "bun": "./src/index.ts",
      "worker": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "bun": "./src/*.ts",
      "worker": "./src/*.ts",
      "import": "./lib/*.js"
    },
    "./openapi/generate": {
      "bun": "./scripts/generate-openapi.ts",
      "default": "./scripts/generate-openapi.ts"
    }
  },
  "scripts": {
    "prebuild": "node node_modules/typescript-compiler/bin/tsc -b tsconfig.build.json --clean",
    "check": "bun run typecheck && bun test",
    "build": "node node_modules/typescript-compiler/bin/tsc -p tsconfig.build.json",
    "docs:build": "bun run docs:check && blume build --strict",
    "docs:check": "bun scripts/sdk-docs.ts",
    "docs:check:registry": "bun scripts/sdk-docs.ts --registry",
    "docs:dev": "blume dev",
    "docs:generate": "bun scripts/sdk-docs.ts --write",
    "docs:preview": "blume preview",
    "docs:sync": "blume sync",
    "typecheck": "node node_modules/typescript-compiler/bin/tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.97 || >=4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "blume": "1.0.4",
    "effect": "4.0.0-beta.98",
    "typescript": "6.0.3",
    "typescript-compiler": "npm:typescript@7.0.2"
  }
}
